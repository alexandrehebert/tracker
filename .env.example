# OpenSky API credentials
OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# Aviation Stack API key
AVIATION_STACK_API_KEY=

# FlightAware AeroAPI key
FLIGHT_AWARE_API_KEY=
# Legacy alias still accepted by the app:
# FLIGHTAWARE_API_KEY=

# Optional provider feature flags
# Leave blank to keep all providers enabled, or set a comma-separated allowlist like: opensky,flightaware
ENABLED_API_PROVIDERS=
# Optional comma-separated blocklist override, for example: aviationstack
DISABLED_API_PROVIDERS=
# Optional per-provider hard overrides
OPENSKY_DISABLED=false
FLIGHTAWARE_DISABLED=false
AVIATIONSTACK_DISABLED=false

# Optional: when set on Vercel, the cron endpoint expects `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=
# Local Docker cron sidecar overrides
TRACKER_CRON_URL=http://tracker:4109/api/tracker/cron
TRACKER_CRON_INTERVAL_SECONDS=900
TRACKER_CRON_STARTUP_DELAY_SECONDS=20

# Server-side flight cache (optional overrides)
MONGODB_URI=mongodb://localhost:27017/tracker
MONGODB_DB_NAME=tracker
OPENSKY_CACHE_TTL_SECONDS=300
# Optional: increase the OpenSky HTTP timeout in slower/serverless environments like Vercel
OPENSKY_REQUEST_TIMEOUT_MS=25000
