# OpenSky API credentials
OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# Aviation Stack API key
AVIATION_STACK_API_KEY=

# FlightAware AeroAPI key
FLIGHT_AWARE_API_KEY=
# Legacy alias still accepted by the app:
# FLIGHTAWARE_API_KEY=

# AirLabs live flight API key
AIRLABS_API_KEY=
# Optional cache tuning for AirLabs responses
AIRLABS_CACHE_TTL_SECONDS=300

# AeroDataBox via RapidAPI (used only for the per-flight "Validate flight" action to preserve quota)
RAPIDAPI_AERODATABOX_API_KEY=
# Optional alias if you prefer a provider-specific name:
# AERODATABOX_RAPIDAPI_KEY=
# Optional request pacing and cache tuning for low-quota plans
AERODATABOX_MIN_REQUEST_GAP_MS=1200
AERODATABOX_CACHE_TTL_SECONDS=43200

# Optional provider feature flags
# Leave blank to keep all providers enabled, or set a comma-separated allowlist like: opensky,flightaware,aerodatabox
ENABLED_API_PROVIDERS=
# Optional comma-separated blocklist override, for example: aviationstack,airlabs,aerodatabox
DISABLED_API_PROVIDERS=
# Optional per-provider hard overrides
OPENSKY_DISABLED=false
FLIGHTAWARE_DISABLED=false
AVIATIONSTACK_DISABLED=false
AIRLABS_DISABLED=false
AERODATABOX_DISABLED=false

# Optional: when set on Vercel, the cron endpoint expects `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=

# Recommended on Vercel when direct outbound access to opensky-network.org times out:
# point the app at a small external proxy/relay, for example:
# - Docker host running `docker/opensky-proxy-server.mjs`
# - Scaleway Serverless Function from `scaleway/opensky-proxy/`
OPENSKY_PROXY_URL=
# Optional shared secret sent as `x-opensky-proxy-secret` to protect that proxy
OPENSKY_PROXY_SECRET=
# Optional timeout for the proxy itself when it calls OpenSky upstream
OPENSKY_PROXY_UPSTREAM_TIMEOUT_MS=12000
# Local Docker cron sidecar overrides
TRACKER_CRON_URL=http://tracker:4109/api/tracker/cron
TRACKER_CRON_INTERVAL_SECONDS=900
TRACKER_CRON_STARTUP_DELAY_SECONDS=20
# Optional: query OpenSky in smaller cron batches to stay gentler with rate limits/credits
TRACKER_CRON_OPENSKY_BATCH_SIZE=4
TRACKER_CRON_OPENSKY_BATCH_DELAY_MS=1500

# Server-side flight cache (optional overrides)
MONGODB_URI=mongodb://localhost:27017/tracker
MONGODB_DB_NAME=tracker
OPENSKY_CACHE_TTL_SECONDS=300
# Optional: keep more recent points/snapshots in the summary cache documents.
# Full Wayback history is archived separately in Mongo when available; set to 0 to disable summary trimming.
TRACKER_SHARED_CACHE_MAX_TRACK_POINTS=600
TRACKER_SHARED_CACHE_MAX_FETCH_HISTORY=2500
# Optional: increase the OpenSky request timeout in slower/serverless environments like Vercel
OPENSKY_REQUEST_TIMEOUT_MS=25000
# Optional: increase the underlying TCP connect timeout used by Node/Undici before the TLS session is established
OPENSKY_CONNECT_TIMEOUT_MS=30000
